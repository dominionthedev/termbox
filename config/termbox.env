# termbox.env — Runtime Contract
# =============================================================================
# This file is the bridge between Termbox and your shell.
# It is sourced by your shell BEFORE the termbox zshrc.
#
# Add exactly these two lines to the TOP of ~/.zshrc:
#
#   # ---- termbox env ----
#   source $HOME/Developer/termbox/config/termbox.env
#   # ---- termbox zsh ----
#   source $TERMBOX_HOME/config/shell/zshrc
#
# Generated/updated by: termbox setup --wizard
# Manual edits are safe — wizard only rewrites its own keys.
# =============================================================================

# ── Paths ─────────────────────────────────────────────────────────────────────
export TERMBOX_HOME="$HOME/Developer/termbox"
export DEV_HOME="$HOME/Developer"            # your projects root
export NOTE_FOLDER="$HOME/Developer/notes"  # where noter stores notes

# ── Defaults — Configs ────────────────────────────────────────────────────────
export TERMBOX_DEFAULT_NVIM="default"        # nvim config name (termbox use nvim.<name>)
export TERMBOX_DEFAULT_STARSHIP="default"    # starship config name
export TERMBOX_DEFAULT_TMUX="default"        # tmux config name
export TERMBOX_DEFAULT_SHELL="zsh"          # preferred shell

# ── Defaults — Tools ──────────────────────────────────────────────────────────
export TERMBOX_EDITOR="nvim"                 # default editor (overrides $EDITOR in termbox context)
export TERMBOX_PAGER="bat"                   # default pager

# ── Theme ─────────────────────────────────────────────────────────────────────
export SHELL_THEME="redwood"

# ── Banner ────────────────────────────────────────────────────────────────────
export BANNER="$TERMBOX_HOME/assets/dominiondev.banner"
export TERMBOX_SHOW_BANNER="true"            # false to disable startup banner

# ── Powerup ──────────────────────────────────────────────────────────────────
export TERMBOX_POWERUP="core"               # active powerup (set by: termbox powerup activate)

# ── PATH Injection ────────────────────────────────────────────────────────────
# termbox bin/ is prepended so built tools (noter, banner, etc.) are available
export PATH="$TERMBOX_HOME/bin:$PATH"
